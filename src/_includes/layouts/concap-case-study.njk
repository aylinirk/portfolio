    .metrics-banner { flex-direction: column; padding: 32px 24px; gap: 24px; }
    .metric-item { border-right: none; border-bottom: 1px solid var(--border); padding-bottom: 20px; }
    .metric-item:last-child { border-bottom: none; padding-bottom: 0; }
    .principles-grid { grid-template-columns: 1fr; }
    .outcomes-grid { grid-template-columns: 1fr; }
    .quotes-row { grid-template-columns: 1fr; }
    .back-bar { padding: 14px 24px; }
