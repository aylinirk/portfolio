  .dark-box p:last-child { margin-bottom: 0; }

  /* INSIGHT QUOTE */
  .insight { background: var(--cream); border-left: 4px solid var(--blue-mid); border-radius: 0 16px 16px 0; padding: 32px 40px; margin: 40px 0; }
  .insight p { font-family: 'Playfair Display', serif; font-size: 20px; font-style: italic; color: var(--text); line-height: 1.55; margin-bottom: 12px; }
  .insight .attr { font-size: 12px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--blue-mid); }

  /* PRINCIPLES */
  .principles-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 32px 0; }
  .principle-card { background: white; border: 1px solid var(--border); border-radius: 16px; padding: 28px; }
  .principle-number { font-family: 'Playfair Display', serif; font-size: 42px; font-weight: 800; color: var(--blue-pale); line-height: 1; margin-bottom: 12px; }
  .principle-card h4 { font-size: 15px; font-weight: 600; color: var(--text); margin-bottom: 8px; }
  .principle-card p { font-size: 14px; color: var(--text-muted); line-height: 1.65; }

  /* TIMELINE */
  .timeline { position: relative; margin: 32px 0; }
  .timeline::before { content: ''; position: absolute; left: 28px; top: 0; bottom: 0; width: 2px; background: var(--blue-pale); }
  .timeline-item { display: flex; gap: 24px; margin-bottom: 36px; position: relative; }
  .timeline-dot { width: 56px; height: 56px; border-radius: 50%; background: white; border: 2px solid var(--blue-pale); display: flex; align-items: center; justify-content: center; flex-shrink: 0; position: relative; z-index: 1; }
  .timeline-dot span { font-family: 'Playfair Display', serif; font-size: 18px; font-weight: 800; color: var(--blue-mid); }
  .timeline-content { padding-top: 10px; flex: 1; }
  .timeline-tag { display: inline-block; background: var(--blue-pale); color: var(--navy); padding: 2px 10px; border-radius: 20px; font-size: 11px; font-weight: 600; margin-bottom: 8px; letter-spacing: 0.05em; text-transform: uppercase; }
  .timeline-content h4 { font-size: 16px; font-weight: 600; color: var(--text); margin-bottom: 6px; }
  .timeline-content p { font-size: 14px; color: var(--text-muted); line-height: 1.75; }

  /* DECISIONS */
  .decisions-list { display: flex; flex-direction: column; gap: 16px; margin: 32px 0; }
  .decision-item { background: white; border: 1px solid var(--border); border-left: 4px solid var(--blue-mid); border-radius: 0 14px 14px 0; padding: 22px 28px; }
  .decision-item h4 { font-size: 15px; font-weight: 600; color: var(--text); margin-bottom: 7px; }
  .decision-item p { font-size: 14px; color: var(--text-muted); line-height: 1.65; }

  /* OUTCOMES */
  .outcomes-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin: 32px 0; }
  .outcome-card { background: white; border: 1px solid var(--border); border-radius: 16px; padding: 28px 20px; text-align: center; }
  .outcome-value { font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 800; color: var(--terra); line-height: 1.1; margin-bottom: 10px; }
  .outcome-label { font-size: 12px; color: var(--text-muted); font-weight: 500; line-height: 1.4; }

  /* USER QUOTES */
  .quotes-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 24px 0; }
  .user-quote { background: white; border: 1px solid var(--border); border-radius: 14px; padding: 24px; position: relative; }
  .user-quote::before { content: '\201C'; font-family: 'Playfair Display', serif; font-size: 48px; color: var(--blue-pale); position: absolute; top: 8px; left: 16px; line-height: 1; }
  .user-quote p { font-size: 14px; color: var(--text); font-style: italic; line-height: 1.6; padding-left: 24px; padding-top: 16px; }

  /* REFLECTION */
  .reflection-pull { background: linear-gradient(135deg, #0d1a3a, #1a2d6b); border-radius: 20px; padding: 44px; margin: 32px 0; }
  .reflection-pull p { font-family: 'Playfair Display', serif; font-size: 22px; font-style: italic; color: var(--blue-light); line-height: 1.5; }

  .prose p { color: #374151; margin-bottom: 16px; font-size: 15px; line-height: 1.85; }
  .prose ul { margin: 12px 0 16px 20px; }
  .prose li { font-size: 15px; color: #374151; margin-bottom: 6px; line-height: 1.7; }

  /* TOOLS */
  .tools-row { display: flex; flex-wrap: wrap; gap: 10px; margin: 24px 0; }
  .tool-pill { background: white; border: 1px solid var(--border); padding: 8px 16px; border-radius: 30px; font-size: 13px; font-weight: 500; color: var(--text); display: flex; align-items: center; gap: 6px; }
  .tool-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--blue-mid); }

  .divider { height: 1px; background: var(--border); margin: 56px 0; }
  .page-break { padding-top: 56px; }

  .doc-footer { background: #0d1a3a; color: rgba(255,255,255,0.5); padding: 32px 60px; display: flex; justify-content: space-between; align-items: center; font-size: 12px; }
