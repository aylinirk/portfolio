    {% if isDE %}
    <p>Mit mehr Zeit würde ich die Barrierefreiheit vertiefen — insbesondere für ältere Nutzer:innen, die als Schmerzpunkt identifiziert wurden. Ausserdem würde ich einen zweiten Usability-Test mit dem Hi-Fi-Prototyp durchführen, um zu prüfen ob die Überarbeitungen wirklich geholfen haben.</p>
    {% else %}
    <p>With more time I would deepen the accessibility work — especially for older users, who were identified as a pain point. I would also run a second usability test with the hi-fi prototype to check whether the revisions actually helped.</p>
    {% endif %}
  </div>
</div>

<script>
  function initSlider(gridId, dotsId) {
    const grid = document.getElementById(gridId);
    const dotsEl = document.getElementById(dotsId);
    if (!grid || !dotsEl) return;

    const cells = grid.querySelectorAll('.screen-cell');
    const count = cells.length;

    // Build dots
    for (let i = 0; i < count; i++) {
      const d = document.createElement('div');
      d.className = 'dot' + (i === 0 ? ' dot-active' : '');
      dotsEl.appendChild(d);
    }

    const dots = dotsEl.querySelectorAll('.dot');

    function updateDots() {
      const cellW = grid.offsetWidth;
      if (!cellW) return;
      const idx = Math.round(grid.scrollLeft / cellW);
      dots.forEach((d, i) => d.classList.toggle('dot-active', i === idx));
    }

    grid.addEventListener('scroll', updateDots, { passive: true });
  }

  initSlider('lofi-grid', 'lofi-dots');
  initSlider('hifi-grid', 'hifi-dots');
</script>
