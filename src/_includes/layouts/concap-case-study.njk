  .cover::before { content: ''; position: absolute; top: -80px; right: -80px; width: 420px; height: 420px; border-radius: 50%; background: rgba(147,197,253,0.08); }
  .cover::after { content: ''; position: absolute; bottom: -40px; left: 160px; width: 280px; height: 280px; border-radius: 50%; background: rgba(96,130,246,0.1); }
  .cover-tag { display: inline-block; background: rgba(147,197,253,0.2); border: 1px solid rgba(147,197,253,0.4); color: var(--blue-light); padding: 6px 16px; border-radius: 30px; font-size: 12px; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 32px; }
  .cover h1 { font-family: 'Playfair Display', serif; font-size: 64px; font-weight: 800; line-height: 1; margin-bottom: 20px; position: relative; z-index: 1; }
  .cover h1 span { color: var(--blue-light); }
  .cover-sub { font-size: 18px; color: rgba(255,255,255,0.65); margin-bottom: 56px; max-width: 600px; position: relative; z-index: 1; line-height: 1.6; }
  .cover-meta { display: flex; gap: 48px; position: relative; z-index: 1; flex-wrap: wrap; }
  .cover-meta-item label { display: block; font-size: 10px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 5px; }
  .cover-meta-item span { font-size: 14px; color: rgba(255,255,255,0.88); font-weight: 500; }
  .cover-pills { position: absolute; bottom: 60px; right: 60px; display: flex; flex-direction: column; gap: 8px; z-index: 1; }
  .skill-pill { background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.13); color: rgba(255,255,255,0.7); padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 500; text-align: center; }

  /* METRICS BANNER */
  .metrics-banner { background: white; border-bottom: 1px solid var(--border); padding: 40px 60px; display: flex; gap: 0; }
  .metric-item { flex: 1; text-align: center; padding: 0 24px; border-right: 1px solid var(--border); }
  .metric-item:last-child { border-right: none; }
  .metric-value { font-family: 'Playfair Display', serif; font-size: 40px; font-weight: 800; color: var(--blue-mid); line-height: 1; margin-bottom: 8px; }
  .metric-label { font-size: 12px; color: var(--text-muted); font-weight: 500; line-height: 1.4; }

  /* PAGE */
  .page { max-width: 900px; margin: 0 auto; padding: 64px 60px; }
  .section-number { font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; color: var(--blue-light); margin-bottom: 8px; }
  .section-title { font-family: 'Playfair Display', serif; font-size: 32px; font-weight: 700; color: var(--text); margin-bottom: 32px; padding-bottom: 16px; border-bottom: 2px solid var(--blue-pale); }

  /* DARK BOX */
  .dark-box { background: #0d1a3a; color: white; border-radius: 20px; padding: 44px; margin: 32px 0; }
  .dark-box h3 { font-family: 'Playfair Display', serif; font-size: 22px; margin-bottom: 18px; color: var(--blue-light); }
