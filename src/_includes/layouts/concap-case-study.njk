<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --navy: #0d1a3a;
    --blue-mid: #1e3a8a;
    --blue-light: #93c5fd;
    --blue-pale: #dbeafe;
    --cream: #f0f4ff;
    --terra: #f59f00;
    --text: #1a1a2e;
    --text-muted: #6b7280;
    --border: #e5e7eb;
    --bg: #f9fafb;
  }
  body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text); font-size: 16px; line-height: 1.7; }

  .back-bar { background: #0d1a3a; padding: 14px 60px; }
  .back-bar a { color: rgba(255,255,255,0.6); text-decoration: none; font-size: 13px; font-weight: 500; letter-spacing: 0.03em; transition: color 0.2s; }
  .back-bar a:hover { color: rgba(255,255,255,0.9); }

  /* COVER */
